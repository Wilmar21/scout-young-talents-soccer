# ─── Datos fuente (demasiado grandes para el repo) ───────────
data/
*.csv
*.parquet
*.feather
*.pkl
*.pickle
*.h5
*.hdf5

# ─── Outputs generados (se reproducen ejecutando el código) ──
outputs/

# ─── MLflow (se genera localmente al ejecutar) ───────────────
mlruns/
mlartifacts/

# ─── Entorno virtual ─────────────────────────────────────────
venv/
env/
.env/
.venv/
ENV/

# ─── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# ─── Jupyter ─────────────────────────────────────────────────
.ipynb_checkpoints/
*/.ipynb_checkpoints/*
profile_default/
ipython_config.py

# ─── PyCharm ─────────────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr

# ─── Variables de entorno y secretos ─────────────────────────
.env
.env.local
*.env
secrets.py
config_local.py

# ─── Sistema operativo ───────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# ─── Logs ────────────────────────────────────────────────────
*.log
logs/

# ─── Modelos entrenados (pueden ser grandes) ─────────────────
*.model
*.bin
models/

# ─── Cobertura y testing ─────────────────────────────────────
htmlcov/
.coverage
.pytest_cache/

# ─── Scripts de desarrollo (contenido migrado a notebooks) ───
scripts/